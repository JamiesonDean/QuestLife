# ── Local owner instance ─────────────────────────────────────────────────────
# Copy to `.env.local` (never committed):
#   VITE_APP_MODE=owner
#
# Your personal quests live in `private/` — that folder is gitignored and
# never pushed to GitHub. It stays on your machine only.
#
#   npm run dev          → http://localhost:5173 (your game)
#   npm run dev:public   → http://localhost:5174 (Morgan demo)

# ── Public demo / Cloudflare deploy ─────────────────────────────────────────
#   npm run build:public
#   npm run dev:public

VITE_APP_MODE=owner
