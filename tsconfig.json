{
  "compilerOptions": {
    "target": "ES2022",
    "baseUrl": ".",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    "strict": true,
    "ignoreDeprecations": "6.0",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@questlife/catalog": ["./src/catalog/public.ts"],
      "@questlife/ownerRegistry": ["./src/owner/registryOwner.stub.ts"],
      "@questlife/epicIcons": ["./src/assets/epicIconConfigs.public.ts"],
      "@questlife/playerAvatar": ["./src/assets/playerAvatar.public.ts"]
    }
  },
  "include": ["src"]
}
